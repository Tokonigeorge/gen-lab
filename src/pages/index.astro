---
/**
 * Generative Lab — Gallery Index
 * A grid of all experiments with name and one-line description.
 */
const experiments = [
  {
    id: '001',
    slug: '001',
    title: 'Flow Field',
    description: 'Particles tracing paths through a simplex noise vector field, with curl noise for vortices.',
  },
  {
    id: '002',
    slug: '002',
    title: 'Bohemian Eigenvalues',
    description: 'All eigenvalues of every matrix in a Bohemian family, scattered on the complex plane.',
  },
  {
    id: '003',
    slug: '003',
    title: 'Reaction-Diffusion',
    description: 'Gray-Scott model: two chemicals diffuse and react, self-organizing into spots, stripes, and mazes.',
  },
  {
    id: '004',
    slug: '004',
    title: 'Strange Attractors',
    description: 'Density plots of chaotic dynamical systems — Lorenz, Clifford, de Jong, and Dadras attractors in phase space.',
  },
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Generative Lab</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: #0a0a0f;
      color: #e0e0e0;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      min-height: 100dvh;
      padding: 48px 32px;
    }

    header {
      max-width: 720px;
      margin: 0 auto 48px;
    }

    header h1 {
      font-size: 20px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #6a8cff;
      margin-bottom: 8px;
    }

    header p {
      font-size: 13px;
      color: #666;
      line-height: 1.6;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      max-width: 960px;
      margin: 0 auto;
    }

    .card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      padding: 24px;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, background 0.2s;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .card:hover {
      border-color: rgba(106, 140, 255, 0.3);
      background: rgba(255, 255, 255, 0.05);
    }

    .card .id {
      font-size: 11px;
      color: #555;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .card .title {
      font-size: 15px;
      font-weight: 600;
      color: #ddd;
    }

    .card .desc {
      font-size: 12px;
      color: #777;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <header>
    <h1>Generative Lab</h1>
    <p>A personal lab for generative art and math visualization. Each experiment is self-contained and written to be read. <a href="/math" style="color: #6a8cff;">Math companion →</a></p>
  </header>

  <div class="grid">
    {experiments.map((exp) => (
      <a class="card" href={`/${exp.slug}`}>
        <span class="id">{exp.id}</span>
        <span class="title">{exp.title}</span>
        <span class="desc">{exp.description}</span>
      </a>
    ))}
  </div>
</body>
</html>
